<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Trip</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Garage,analytics.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @if (ViewData["IsDashboard"] == null)
    {
        <nav class="navbar navbar-expand-md st-navbar sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="brand-icon-box">
                        <i class="bi bi-fuel-pump-fill"></i>
                    </div>
                    <div class="brand-text ms-2">
                        <span class="brand-top">SMART</span>
                        <span class="brand-bottom">TRIP</span>
                    </div>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon-custom"><i class="bi bi-grid-fill"></i></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto gap-3">
                        <li class="nav-item"><a class="nav-link nav-link-custom" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link nav-link-custom" href="#features">Features</a></li>
                        <li class="nav-item"><a class="nav-link nav-link-custom" href="#how-it-works">Process</a></li>
                    </ul>

                    <div class="nav-auth-buttons">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    }

    <main role="main" class="@(ViewData["IsDashboard"] != null ? "pb-5" : "")">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>