@model TripCardViewModel
<div class="trip-item" id="unique-trip-card">
    <div class="trip-dot-static">
        <i class="bi bi-geo-alt-fill"></i>
    </div>
    <div class="trip-info">
        <div class="trip-route">@Model.OriginName <span class="via">to</span> @Model.DestinationName</div>
        <div class="trip-meta">@Model.TripDate &nbsp;·&nbsp; @Model.DistanceKm km &nbsp;·&nbsp; @Model.VehicleName</div>
    </div>
    <div class="trip-status-area">
        <div class="trip-price">EGP @Model.TripTotalCost</div>
        <div class="priority-tag medium"></div>
    </div>
</div>