@{
    ViewData["Title"] = "Analytics";
}

<section class="analytics-header">
    <div>
        <h1 class="analytics-title">Analytics</h1>
        <p class="analytics-subtitle">Your travel insights</p>
    </div>
    <span class="time-pill">All Time</span>
</section>

<section class="row g-3">
    <div class="col-lg-6">
        <div class="analytics-kpi">
            <span class="kpi-icon kpi-icon-teal">km</span>
            <div class="kpi-value">1,835 km</div>
            <div class="kpi-label">Total Distance</div>
            <div class="kpi-sub">5 trips</div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="analytics-kpi">
            <span class="kpi-icon kpi-icon-purple">$</span>
            <div class="kpi-value">EGP 2,674.5</div>
            <div class="kpi-label">Total Spent</div>
            <div class="kpi-sub">Avg EGP 535/trip</div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="analytics-kpi">
            <span class="kpi-icon kpi-icon-amber">F</span>
            <div class="kpi-value">EGP 1,949.25</div>
            <div class="kpi-label">Fuel Cost</div>
            <div class="kpi-sub">73% of total</div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="analytics-kpi">
            <span class="kpi-icon kpi-icon-green">CO2</span>
            <div class="kpi-value">240.7 kg</div>
            <div class="kpi-label">CO2 Emissions</div>
            <div class="kpi-sub">131 g/km</div>
        </div>
    </div>
</section>

<section class="analytics-panel mt-3">
    <h3 class="panel-title">Monthly Spending</h3>
    <div class="chart chart-line">
        <div class="chart-axis-y">
            <span>2800</span>
            <span>2100</span>
            <span>1400</span>
            <span>700</span>
        </div>
        <div class="chart-canvas">
            <div class="line-dot"></div>
        </div>
    </div>
</section>

<section class="analytics-panel mt-3">
    <h3 class="panel-title">Cost Breakdown</h3>
    <div class="breakdown-wrap">
        <div class="donut-chart"></div>
        <div class="breakdown-legend">
            <div class="legend-row"><span><i class="dot dot-fuel"></i>Fuel</span><strong>73%</strong></div>
            <div class="legend-row"><span><i class="dot dot-tolls"></i>Tolls</span><strong>17%</strong></div>
            <div class="legend-row"><span><i class="dot dot-maintenance"></i>Maintenance</span><strong>10%</strong></div>
        </div>
    </div>
</section>

<section class="analytics-panel mt-3">
    <h3 class="panel-title">Distance Traveled</h3>
    <div class="chart chart-bar">
        <div class="chart-axis-y">
            <span>2000 km</span>
            <span>1500 km</span>
            <span>1000 km</span>
            <span>500 km</span>
        </div>
        <div class="chart-canvas">
            <div class="bar-fill"></div>
        </div>
    </div>
</section>

<section class="analytics-panel mt-3">
    <h3 class="panel-title">Environmental Impact</h3>
    <div class="chart chart-line">
        <div class="chart-axis-y">
            <span>260 kg</span>
            <span>195 kg</span>
            <span>130 kg</span>
            <span>65 kg</span>
            <span>0 kg</span>
        </div>
        <div class="chart-canvas">
            <div class="line-dot line-dot-green"></div>
        </div>
    </div>
</section>
