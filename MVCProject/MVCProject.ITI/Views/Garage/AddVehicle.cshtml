@using MVCProject.ITI.DataAccessLayer.Entities
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@model MVCProject.ITI.ViewModels.AddVechileViewModel
@{
    ViewData["Title"] = "Add";
    Layout = "_AppLayout";
}
<section class="vehicle-form-card">
    <h1 class="analytics-title mb-3">
        @(Model.VehicleId == Guid.Empty ? "Add" : "Edit")
    </h1>
    <form method="post" asp-action="@(Model.VehicleId == Guid.Empty ? "AddVehicle" : "Edit")">

        <input type="hidden" asp-for="VehicleId" />
        <input type="hidden" asp-for="CarModelId" />
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">Nickname</label>
                <input class="form-control" asp-for="NickName" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Brand</label>
                <input class="form-control" asp-for="Make" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Model</label>
                <input class="form-control" asp-for="Model" />
            </div>

            <div class="col-12">
                <label class="form-label">Year</label>
                <input class="form-control" asp-for="Year"/>
            </div>
        </div>
        <div class="mt-3">
            <label class="form-label" >Fuel Type</label>
            <select asp-for="FuelType" class="form-select" id="FuelType">
                <option value="Gasoline">Gasoline</option>
                <option value="Diesel">Diesel</option>
                <option value="Electric">Electric</option>
                <option value="Hybrid">Hybrid</option>
            </select>
        </div>
        <div class="mt-3">
            <label>Consumption(L/100km)</label>
            <input asp-for="WltpMixed" class="form-control" />

            </div>
        </div>

        <div class="col-md-6 mt-3">
            <label class="form-label">Tank (L)</label>
            <input class="form-control" asp-for="TankCapacity" id="TankCapacity" />
        </div>

    <div class="col-md-6 mt-3" id="batterySection" style="display:none;">
        <label class="form-label">Battery (kWh)</label>
        <input class="form-control" asp-for="BatteryCapacity" id="BatteryCapacity" />
    </div>

        <div class="mt-3">
            <label class="form-label">Color</label>

            <input asp-for="ColorHex" type="hidden" id="colorInput" />

            <div class="color-palette">
                <button type="button" class="color-dot" style="--dot-color:#f0f0f0;" data-color="#f0f0f0"></button>
                <button type="button" class="color-dot" style="--dot-color:#000;" data-color="#000"></button>
                <button type="button" class="color-dot" style="--dot-color:#cc000a;" data-color="#cc000a"></button>
                <button type="button" class="color-dot" style="--dot-color:#0003d6;" data-color="#0003d6"></button>
                <button type="button" class="color-dot" style="--dot-color:#f59e0b;" data-color="#f59e0b"></button>
                <button type="button" class="color-dot" style="--dot-color:#800000;" data-color="#800000"></button>
                <button type="button" class="color-dot" style="--dot-color:#104e00;" data-color="#104e00"></button>
                <button type="button" class="color-dot" style="--dot-color:#ed6c00;" data-color="#ed6c00"></button>
                <button type="button" class="color-dot" style="--dot-color:#b852ff;" data-color="#b852ff"></button>
                <button type="button" class="color-dot" style="--dot-color:#06b6d4;" data-color="#06b6d4"></button>
            </div>
        </div>
        

        <div class="row g-2 mt-3">
            <div class="col-md-6">
                <a asp-action="Garage" class="btn btn-outline-secondary w-100">Cancel</a>
            </div>

            <div class="col-md-6">
                <button class="btn btn-teal w-100" type="submit">
                    @(Model.VehicleId == Guid.Empty ? "Add" : "Save Changes")
                </button>
            </div>
        </div>

    </form>
<script>
        document.addEventListener("DOMContentLoaded", function () {

            function updateFuelUI() {
             let fuel = document.getElementById("FuelType").value;
             
             let tankDiv = document.getElementById("TankCapacity").closest(".col-md-6");
             let batteryDiv = document.getElementById("batterySection");
             
             if (fuel === "Gasoline" || fuel === "Diesel") {
              tankDiv.style.display = "block";
              batteryDiv.style.display = "none";
              }
             else if (fuel === "Electric") {
             tankDiv.style.display = "none";
             batteryDiv.style.display = "block";
             }
              else if (fuel === "Hybrid") {
              tankDiv.style.display = "block";
              batteryDiv.style.display = "block";
        }
            }

            document.getElementById("FuelType").addEventListener("change", updateFuelUI);

            updateFuelUI(); // مهم جدًا لو الصفحة Edit
        });
</script>

    <script>
            const dots = document.querySelectorAll(".color-dot");
            const input = document.getElementById("colorInput");

            dots.forEach(dot => {
                dot.addEventListener("click", () => {
                    input.value = dot.dataset.color;

                    dots.forEach(d => d.classList.remove("active"));
                    dot.classList.add("active");
                });
            });
    </script>
</section>
