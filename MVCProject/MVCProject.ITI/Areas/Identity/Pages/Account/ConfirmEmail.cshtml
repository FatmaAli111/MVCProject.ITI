@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Email Confirmed";
    Layout = "/Views/Shared/_AppLayout.cshtml";
    bool success = Model.StatusMessage != null && Model.StatusMessage.Contains("Thank you");
}

@section Styles {
    <style>
        .auth-bg {
            min-height: 100vh;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .auth-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            pointer-events: none;
        }

        .auth-orb-1 {
            width: 160px;
            height: 160px;
            background: radial-gradient(circle, rgba(20,184,166,0.30), transparent);
            top: 80px;
            left: 40px;
            animation: float 8s ease-in-out infinite;
        }

        .auth-orb-2 {
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(251,191,36,0.25), transparent);
            bottom: 80px;
            right: 40px;
            animation: float 10s ease-in-out infinite reverse;
        }

        .auth-orb-3 {
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(13,148,136,0.12), transparent);
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            filter: blur(80px);
            animation: pulse-glow 6s ease-in-out infinite;
        }

        .auth-main {
            position: relative;
            z-index: 10;
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.25rem 3rem;
        }

        .auth-inner {
            width: 100%;
            max-width: 440px;
        }

        .confirm-card {
            background: rgba(255,255,255,0.88);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.65);
            border-radius: 28px;
            padding: 2.5rem 2rem;
            box-shadow: 0 20px 60px rgba(13,148,136,0.15);
            text-align: center;
        }

        .confirm-icon-wrap {
            display: flex;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .confirm-icon {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 38px;
            color: #fff;
            animation: pop-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
        }

            .confirm-icon.success {
                background: linear-gradient(135deg, #0d9488, #14b8a6);
                box-shadow: 0 0 40px rgba(20,184,166,0.45);
            }

            .confirm-icon.error {
                background: linear-gradient(135deg, #dc2626, #ef4444);
                box-shadow: 0 0 40px rgba(220,38,38,0.35);
            }
        @@keyframes pop-in {
            from

        {
            transform: scale(0.4);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }

        }

        .confirm-title {
            font-size: 1.75rem;
            font-weight: 900;
            color: var(--foreground);
            margin-bottom: 0.5rem;
        }

        .confirm-subtitle {
            font-size: 0.95rem;
            color: var(--muted-fg);
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .confirm-checklist {
            list-style: none;
            padding: 0;
            margin: 0 0 2rem;
            text-align: left;
        }

            .confirm-checklist li {
                display: flex;
                align-items: center;
                gap: 10px;
                font-size: 0.9rem;
                color: var(--foreground);
                padding: 0.5rem 0;
                border-bottom: 1px solid var(--border);
            }

                .confirm-checklist li:last-child {
                    border-bottom: none;
                }

            .confirm-checklist .bi-check-circle-fill {
                color: var(--primary);
                font-size: 16px;
                flex-shrink: 0;
            }

        .btn-dashboard {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            height: 52px;
            border: none;
            border-radius: 14px;
            font-weight: 700;
            font-size: 1rem;
            color: #fff;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: transform var(--transition), box-shadow var(--transition);
            text-decoration: none;
        }

            .btn-dashboard:hover {
                transform: translateY(-2px) scale(1.02);
                box-shadow: 0 12px 28px rgba(13,148,136,0.45);
                color: #fff;
            }

            .btn-dashboard:active {
                transform: scale(0.97);
            }

        .btn-login {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            height: 52px;
            border: 2px solid rgba(13,148,136,0.4);
            border-radius: 14px;
            background: transparent;
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--primary);
            text-decoration: none;
            transition: all var(--transition);
        }

            .btn-login:hover {
                border-color: var(--primary);
                background: rgba(13,148,136,0.06);
                color: var(--primary);
            }

        .redirect-notice {
            font-size: 0.78rem;
            color: var(--muted-fg);
            margin-top: 1rem;
        }

        .countdown {
            font-weight: 700;
            color: var(--primary);
        }

        .benefits-row {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 1.5rem;
            flex-wrap: wrap;
        }

        .benefit-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: var(--muted-fg);
        }

            .benefit-item .bi {
                color: var(--primary);
                font-size: 13px;
            }
    </style>
}

<div class="auth-bg mesh-gradient">
    <div class="auth-orb auth-orb-1"></div>
    <div class="auth-orb auth-orb-2"></div>
    <div class="auth-orb auth-orb-3"></div>

    <div class="auth-main">
        <div class="auth-inner fade-up">

            <div class="confirm-card">

                @if (success)
                {
                    <div class="confirm-icon-wrap">
                        <div class="confirm-icon success">
                            <i class="bi bi-check-lg"></i>
                        </div>
                    </div>

                    <div class="confirm-title">Email Confirmed!</div>
                    <div class="confirm-subtitle">
                        Your account has been verified and you're all set.<br />
                        Welcome to <strong>Smart Trip</strong> 🎉
                    </div>

                    <ul class="confirm-checklist">
                        <li><i class="bi bi-check-circle-fill"></i> Email address verified</li>
                        <li><i class="bi bi-check-circle-fill"></i> Account fully activated</li>
                        <li><i class="bi bi-check-circle-fill"></i> Ready to track your trips</li>
                    </ul>

                    <a asp-controller="Dashboard" asp-action="Dashboard" class="btn-dashboard gradient-bg mb-3">
                        <i class="bi bi-speedometer2"></i>
                        Go to Dashboard
                        <div class="shimmer"></div>
                    </a>

                    <p class="redirect-notice">
                        Redirecting automatically in <span class="countdown" id="countdown">5</span>s...
                    </p>
                }
                else
                {
                    <div class="confirm-icon-wrap">
                        <div class="confirm-icon error">
                            <i class="bi bi-x-lg"></i>
                        </div>
                    </div>

                    <div class="confirm-title">Confirmation Failed</div>
                    <div class="confirm-subtitle">
                        We couldn't confirm your email. The link may have expired or already been used.
                    </div>

                    <a asp-area="Identity" asp-page="/Account/Register" class="btn-dashboard gradient-bg mb-3">
                        <i class="bi bi-arrow-repeat"></i>
                        Register Again
                        <div class="shimmer"></div>
                    </a>

                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-login">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Back to Login
                    </a>
                }

            </div>

            <div class="benefits-row fade-up delay-3">
                <div class="benefit-item"><i class="bi bi-lightning-charge-fill"></i><span>Instant cost analysis</span></div>
                <div class="benefit-item"><i class="bi bi-shield-fill-check"></i><span>Secure &amp; private</span></div>
                <div class="benefit-item"><i class="bi bi-rocket-fill"></i><span>AI-powered insights</span></div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @if (success)
    {
        <script>
            let secs = 5;
            const el = document.getElementById('countdown');
            const timer = setInterval(() => {
                secs--;
                if (el) el.textContent = secs;
                if (secs <= 0) {
                    clearInterval(timer);
                    window.location.href = '@Url.Action("Dashboard", "Dashboard")';
                }
            }, 1000);
        </script>
    }
}
