@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Check Your Email";
    Layout = "/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <style>
        .auth-bg {
            min-height: 100vh;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .auth-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            pointer-events: none;
        }

        .auth-orb-1 {
            width: 160px;
            height: 160px;
            background: radial-gradient(circle, rgba(20,184,166,0.30), transparent);
            top: 80px;
            left: 40px;
            animation: float 8s ease-in-out infinite;
        }

        .auth-orb-2 {
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(251,191,36,0.25), transparent);
            bottom: 80px;
            right: 40px;
            animation: float 10s ease-in-out infinite reverse;
        }

        .auth-orb-3 {
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(13,148,136,0.12), transparent);
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            filter: blur(80px);
            animation: pulse-glow 6s ease-in-out infinite;
        }

        .auth-main {
            position: relative;
            z-index: 10;
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.25rem 3rem;
        }

        .auth-inner {
            width: 100%;
            max-width: 440px;
        }

        .confirm-card {
            background: rgba(255,255,255,0.88);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.65);
            border-radius: 28px;
            padding: 2.5rem 2rem;
            box-shadow: 0 20px 60px rgba(13,148,136,0.15);
            text-align: center;
        }

        .confirm-icon-wrap {
            display: flex;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .confirm-icon {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0d9488, #14b8a6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 38px;
            color: #fff;
            box-shadow: 0 0 40px rgba(20,184,166,0.45);
            animation: pop-in 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
        }
        @@keyframes pop-in {
            from

        {
            transform: scale(0.4);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }

        }

        .confirm-title {
            font-size: 1.75rem;
            font-weight: 900;
            color: var(--foreground);
            margin-bottom: 0.5rem;
        }

        .confirm-subtitle {
            font-size: 0.95rem;
            color: var(--muted-fg);
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .steps-list {
            list-style: none;
            padding: 0;
            margin: 0 0 2rem;
            text-align: left;
        }

            .steps-list li {
                display: flex;
                align-items: flex-start;
                gap: 12px;
                font-size: 0.88rem;
                color: var(--foreground);
                padding: 0.65rem 0;
                border-bottom: 1px solid var(--border);
                line-height: 1.5;
            }

                .steps-list li:last-child {
                    border-bottom: none;
                }

        .step-num {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: var(--primary);
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .btn-login {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            height: 52px;
            border: none;
            border-radius: 14px;
            font-weight: 700;
            font-size: 1rem;
            color: #fff;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: transform var(--transition), box-shadow var(--transition);
            text-decoration: none;
        }

            .btn-login:hover {
                transform: translateY(-2px) scale(1.02);
                box-shadow: 0 12px 28px rgba(13,148,136,0.45);
                color: #fff;
            }

        .benefits-row {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 1.5rem;
            flex-wrap: wrap;
        }

        .benefit-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: var(--muted-fg);
        }

            .benefit-item .bi {
                color: var(--primary);
                font-size: 13px;
            }
    </style>
}

<div class="auth-bg mesh-gradient">
    <div class="auth-orb auth-orb-1"></div>
    <div class="auth-orb auth-orb-2"></div>
    <div class="auth-orb auth-orb-3"></div>

    <div class="auth-main">
        <div class="auth-inner fade-up">

            <div class="confirm-card">

                <div class="confirm-icon-wrap">
                    <div class="confirm-icon">
                        <i class="bi bi-envelope-check-fill"></i>
                    </div>
                </div>

                <div class="confirm-title">Check Your Email</div>
                <div class="confirm-subtitle">
                    We've sent a password reset link.<br />
                    Follow the steps below to regain access.
                </div>

                <ul class="steps-list">
                    <li>
                        <div class="step-num">1</div>
                        <span>Open your email inbox and look for an email from <strong>Smart Trip</strong>.</span>
                    </li>
                    <li>
                        <div class="step-num">2</div>
                        <span>Click the <strong>Reset Password</strong> link inside the email.</span>
                    </li>
                    <li>
                        <div class="step-num">3</div>
                        <span>Choose a new strong password and log back in.</span>
                    </li>
                </ul>

                <a asp-area="Identity" asp-page="/Account/Login" class="btn-login gradient-bg">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Back to Login
                    <div class="shimmer"></div>
                </a>

            </div>

            <div class="benefits-row fade-up delay-3">
                <div class="benefit-item"><i class="bi bi-lightning-charge-fill"></i><span>Instant cost analysis</span></div>
                <div class="benefit-item"><i class="bi bi-shield-fill-check"></i><span>Secure &amp; private</span></div>
                <div class="benefit-item"><i class="bi bi-rocket-fill"></i><span>AI-powered insights</span></div>
            </div>

        </div>
    </div>
</div>
