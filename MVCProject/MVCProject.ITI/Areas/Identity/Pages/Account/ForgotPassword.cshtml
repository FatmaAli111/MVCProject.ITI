@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <style>
        .auth-bg {
            min-height: 100vh;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .auth-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            pointer-events: none;
        }

        .auth-orb-1 {
            width: 160px;
            height: 160px;
            background: radial-gradient(circle, rgba(20,184,166,0.30), transparent);
            top: 80px;
            left: 40px;
            animation: float 8s ease-in-out infinite;
        }

        .auth-orb-2 {
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(251,191,36,0.25), transparent);
            bottom: 80px;
            right: 40px;
            animation: float 10s ease-in-out infinite reverse;
        }

        .auth-orb-3 {
            width: 320px;
            height: 320px;
            background: radial-gradient(circle, rgba(13,148,136,0.12), transparent);
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            filter: blur(80px);
            animation: pulse-glow 6s ease-in-out infinite;
        }

        .auth-main {
            position: relative;
            z-index: 10;
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.25rem 3rem;
        }

        .auth-inner {
            width: 100%;
            max-width: 440px;
        }

        .auth-logo-wrap {
            display: flex;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .auth-logo-icon {
            width: 80px;
            height: 80px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            color: #fff;
            position: relative;
            box-shadow: 0 0 40px -10px rgba(20,184,166,0.5);
        }

            .auth-logo-icon .sparkle-badge {
                position: absolute;
                top: -6px;
                right: -6px;
                width: 28px;
                height: 28px;
                border-radius: 50%;
                background: var(--accent);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                box-shadow: 0 4px 12px rgba(251,191,36,0.5);
            }

        .auth-title {
            text-align: center;
            margin-bottom: 2rem;
        }

            .auth-title h1 {
                font-size: 1.9rem;
                font-weight: 900;
                color: var(--foreground);
                margin-bottom: 0.25rem;
            }

            .auth-title p {
                font-size: 0.9rem;
                color: var(--muted-fg);
            }

        .auth-card {
            background: rgba(255,255,255,0.88);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.65);
            border-radius: 28px;
            padding: 2rem;
            box-shadow: 0 20px 60px rgba(13,148,136,0.15);
        }

        .auth-back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--muted-fg);
            text-decoration: none;
            transition: color var(--transition);
            margin-bottom: 1.25rem;
        }

            .auth-back-link:hover {
                color: var(--primary);
            }

        .auth-info-box {
            background: rgba(13,148,136,0.07);
            border: 1px solid rgba(13,148,136,0.18);
            border-radius: 14px;
            padding: 0.9rem 1rem;
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 1.5rem;
        }

            .auth-info-box .bi {
                color: var(--primary);
                font-size: 18px;
                flex-shrink: 0;
                margin-top: 1px;
            }

            .auth-info-box p {
                margin: 0;
                font-size: 0.84rem;
                color: var(--foreground);
                line-height: 1.5;
            }

        .input-field-group {
            margin-bottom: 1.25rem;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon-box {
            position: absolute;
            left: 12px;
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: rgba(13,148,136,0.10);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            color: var(--primary);
            transition: background var(--transition);
            pointer-events: none;
            z-index: 2;
        }

        .input-wrapper:focus-within .input-icon-box {
            background: rgba(13,148,136,0.18);
        }

        .st-input {
            width: 100%;
            height: 52px;
            padding: 0 1rem 0 60px;
            border: 2px solid var(--border);
            border-radius: 14px;
            background: rgba(255,255,255,0.6);
            font-size: 0.95rem;
            color: var(--foreground);
            transition: border-color var(--transition), box-shadow var(--transition);
            font-family: inherit;
        }

            .st-input::placeholder {
                color: var(--muted-fg);
            }

            .st-input:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(13,148,136,0.12);
                background: rgba(255,255,255,0.95);
            }

        .st-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--foreground);
            margin-bottom: 0.4rem;
        }

        .btn-submit {
            width: 100%;
            height: 52px;
            border: none;
            border-radius: 14px;
            font-weight: 700;
            font-size: 1rem;
            color: #fff;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: transform var(--transition), box-shadow var(--transition);
            margin-top: 0.5rem;
        }

            .btn-submit:hover {
                transform: translateY(-2px) scale(1.02);
                box-shadow: 0 12px 28px rgba(13,148,136,0.45);
            }

            .btn-submit:active {
                transform: scale(0.97);
            }

        .auth-divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: var(--muted-fg);
            font-size: 0.8rem;
            margin: 1.25rem 0;
        }

            .auth-divider::before, .auth-divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border);
            }

        .auth-link-row {
            text-align: center;
        }

            .auth-link-row a {
                font-size: 0.85rem;
                color: var(--primary);
                text-decoration: none;
                font-weight: 600;
            }

                .auth-link-row a:hover {
                    text-decoration: underline;
                }

        .field-validation-error {
            color: #dc2626;
            font-size: 0.78rem;
            display: block;
            margin-top: 4px;
        }

        .input-validation-error {
            border-color: #dc2626 !important;
        }

        .validation-summary-errors ul {
            background: rgba(220,38,38,0.07);
            border: 1px solid rgba(220,38,38,0.25);
            border-radius: 10px;
            padding: 0.7rem 1rem 0.7rem 2rem;
            color: #b91c1c;
            font-size: 0.85rem;
            margin-bottom: 1rem;
        }

        .benefits-row {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 1.5rem;
            flex-wrap: wrap;
        }

        .benefit-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: var(--muted-fg);
        }

            .benefit-item .bi {
                color: var(--primary);
                font-size: 13px;
            }
    </style>
}

<div class="auth-bg mesh-gradient">
    <div class="auth-orb auth-orb-1"></div>
    <div class="auth-orb auth-orb-2"></div>
    <div class="auth-orb auth-orb-3"></div>

    <div class="auth-main">
        <div class="auth-inner fade-up">

            <div class="auth-logo-wrap">
                <div class="auth-logo-icon gradient-bg">
                    <i class="bi bi-car-front-fill"></i>
                    <div class="sparkle-badge">
                        <i class="bi bi-stars" style="font-size:11px; color:#3d2e05;"></i>
                    </div>
                </div>
            </div>

            <div class="auth-title">
                <h1>Reset Password</h1>
                <p>We'll send you a secure link to get back on track</p>
            </div>

            <div class="auth-card">

                <a asp-area="Identity" asp-page="/Account/Login" class="auth-back-link">
                    <i class="bi bi-arrow-left"></i>
                    Back to Login
                </a>

                <div class="auth-info-box">
                    <i class="bi bi-shield-lock-fill"></i>
                    <p>Enter your registered email address and we'll send you a password reset link right away.</p>
                </div>

                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <form method="post">
                    <div class="input-field-group">
                        <label asp-for="Input.Email" class="st-label">Email Address</label>
                        <div class="input-wrapper">
                            <div class="input-icon-box">
                                <i class="bi bi-envelope-fill"></i>
                            </div>
                            <input asp-for="Input.Email"
                                   class="st-input"
                                   autocomplete="username"
                                   placeholder="you@example.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                    </div>

                    <button type="submit" class="btn-submit gradient-bg">
                        Send Reset Link
                        <div class="shimmer"></div>
                    </button>
                </form>

                <div class="auth-divider">or</div>

                <div class="auth-link-row">
                    <a asp-area="Identity" asp-page="/Account/Register">Don't have an account? <strong>Sign Up</strong></a>
                </div>
            </div>

            <div class="benefits-row fade-up delay-3">
                <div class="benefit-item"><i class="bi bi-lightning-charge-fill"></i><span>Instant cost analysis</span></div>
                <div class="benefit-item"><i class="bi bi-shield-fill-check"></i><span>Secure &amp; private</span></div>
                <div class="benefit-item"><i class="bi bi-rocket-fill"></i><span>AI-powered insights</span></div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
